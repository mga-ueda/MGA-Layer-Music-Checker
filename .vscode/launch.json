{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "既定ブラウザで index.html を開く",
      "type": "node-terminal",
      "request": "launch",
      "command": "cmd /c start \"\" \"${workspaceFolder}/index.html\"",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Edge で開く（デバッグ）",
      "type": "msedge",
      "request": "launch",
      "file": "${workspaceFolder}/index.html"
    },
    {
      "name": "Chrome で開く（デバッグ）",
      "type": "chrome",
      "request": "launch",
      "file": "${workspaceFolder}/index.html"
    }
  ]
}
